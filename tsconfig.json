{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "composite": true,
    "incremental": true,
    "paths": {
      "@sybioth/errors": ["./packages/errors/src"],
      "@sybioth/config": ["./packages/config/src"],
      "@sybioth/logger": ["./packages/logger/src"],
      "@sybioth/types": ["./packages/types/src"],
      "@sybioth/utils": ["./packages/utils/src"],
      "@sybioth/event-bus": ["./packages/event-bus/src"],
      "@sybioth/memory": ["./packages/memory/src"],
      "@sybioth/entropy": ["./packages/entropy/src"],
      "@sybioth/protocol": ["./packages/protocol/src"],
      "@sybioth/mcp-federation": ["./packages/mcp-federation/src"],
      "@sybioth/skills": ["./packages/skills/src"],
      "@sybioth/spawner": ["./packages/spawner/src"],
      "@sybioth/hooks": ["./packages/hooks/src"],
      "@sybioth/agents": ["./packages/agents/src"],
      "@sybioth/healing": ["./packages/healing/src"],
      "@sybioth/monitoring": ["./packages/monitoring/src"],
      "@sybioth/efficiency": ["./packages/efficiency/src"],
      "@sybioth/alignment": ["./packages/alignment/src"],
      "@sybioth/security": ["./packages/security/src"],
      "@sybioth/ledger": ["./packages/ledger/src"],
      "@sybioth/runtime": ["./packages/runtime/src"],
      "@sybioth/tui": ["./packages/tui/src"],
      "@sybioth/api": ["./packages/api/src"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "cli/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
